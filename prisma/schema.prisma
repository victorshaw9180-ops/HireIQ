generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id         String      @id @default(cuid())
  name       String
  plan       String      @default("starter")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  candidates Candidate[]
  jobs       Job[]
  members    OrgMember[]
}

model OrgMember {
  id     String       @id @default(cuid())
  orgId  String
  userId String
  role   String       @default("recruiter")
  org    Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, userId])
}

model Job {
  id           String        @id @default(cuid())
  orgId        String
  title        String
  department   String?
  location     String?
  salary       String?
  description  String?
  skills       Json?
  status       String        @default("active")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  org          Organization  @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model Candidate {
  id           String        @id @default(cuid())
  orgId        String
  name         String
  email        String        @unique
  phone        String?
  source       String?
  parsedData   Json?
  createdAt    DateTime      @default(now())
  applications Application[]
  org          Organization  @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model Application {
  id              String     @id @default(cuid())
  candidateId     String
  jobId           String
  orgId           String
  stage           Stage      @default(NEW)
  aiScore         Float?
  matchScore      Float?
  resumeScore     Float?
  skillsScore     Float?
  experienceScore Float?
  scoreReason     String?
  notes           Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  activities      Activity[]
  candidate       Candidate  @relation(fields: [candidateId], references: [id])
  job             Job        @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([candidateId])
  @@index([orgId])
}

model Activity {
  id            String      @id @default(cuid())
  applicationId String
  type          String
  content       String
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
}

enum Stage {
  NEW
  SCREENING
  SHORTLISTED
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}
